import java.util.Scanner;

public class ElectricityBill {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Input Customer Details
        System.out.print("Enter Customer Name: ");
        String name = sc.nextLine();
        System.out.print("Enter Previous Reading: ");
        double prevReading = sc.nextDouble();
        System.out.print("Enter Current Reading: ");
        double currReading = sc.nextDouble();
        System.out.print("Enter Connection Type (1 for Domestic, 2 for Non-Domestic): ");
        int type = sc.nextInt();

        double units = currReading - prevReading;
        double billAmount = 0;

        if (units < 0) {
            System.out.println("Invalid readings: Current reading cannot be less than previous.");
        } else {
            // Calculation Logic
            if (type == 1) { // Domestic
                if (units <= 100) {
                    billAmount = units * 4.80;
                } else if (units <= 200) {
                    billAmount = (100 * 4.80) + ((units - 100) * 5.80);
                } else {
                    billAmount = (100 * 4.80) + (100 * 5.80) + ((units - 200) * 6.50);
                }
            } else if (type == 2) { // Non-Domestic
                billAmount = units * 6.05;
            } else {
                System.out.println("Invalid Connection Type.");
                return;
            }

            // Output Bill
            System.out.println("\n--- Electricity Bill ---");
            System.out.println("Customer Name: " + name);
            System.out.println("Units Consumed: " + units);
            System.out.printf("Total Bill Amount: Rs. %.2f\n", billAmount);
        }
        sc.close();
    }
}
